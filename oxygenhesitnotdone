    public void startGame() {
        if (!worldInitialized) {
            getLogger().warning("Cannot start game - plugin not initialized!");
            Bukkit.broadcastMessage(ChatColor.RED + "Cannot start: Plugin not initialized. Use /forceinit to retry.");
            return;
        }

        if (gameState != GameState.WAITING) {
            getLogger().warning("Game is already running!");
            Bukkit.broadcastMessage(ChatColor.RED + "Game is already running! Use /stop first.");
            return;
        }

        if (teams.isEmpty()) {
            getLogger().warning("Cannot start game - no teams available!");
            Bukkit.broadcastMessage(ChatColor.RED + "Cannot start: No teams available. Use /resetteams.");
            return;
        }

        if (gameWorld == null) {
            getLogger().warning("Cannot start game - world not initialized!");
            Bukkit.broadcastMessage(ChatColor.RED + "Cannot start: World not ready. Use /forceinit.");
            return;
        }

        // Notify proxy that game is starting
        if (proxyAvailable) {
            notifyProxyGameStarted();
            sendProxyCountdown(10, "Oxygen Heist starting!");
        }

        gameState = GameState.COUNTDOWN;
        initializeWorldBorder();

        // Teleport players to their team spawns
        for (Player player : Bukkit.getOnlinePlayers()) {
            String teamName = getPlayerTeam(player);
            if (teamName != null) {
                Location spawn = getTeamSpawn(teamName);
                if (spawn != null) {
                    player.teleport(spawn);
                    player.setGameMode(GameMode.ADVENTURE);
                    player.setFlying(false);
                    player.setAllowFlight(false);
                    freezePlayer(player);

                    // Send team message
                    ChatColor color = teamColors.get(teamName);
                    player.sendMessage(color + "You're on team " + teamName + "!");

                    // Award initial points via proxy
                    if (proxyAvailable) {
                        awardProxyPoints(player, 10, "Game participation");
                    }
                }
            } else {
                getLogger().warning("Player " + player.getName() + " has no team assignment!");
                // Assign to a random team
                String[] teamNames = {"Orca", "Seahorse", "Turtle", "Dolphin", "Swordfish", "Stingray", "Jellyfish", "Octopus"};
                String randomTeam = teamNames[new Random().nextInt(teamNames.length)];
                teams.computeIfAbsent(randomTeam, name -> new TeamData(name, teamColors.get(name)))
                        .members.add(player.getUniqueId());
                playerTeams.put(player.getUniqueId(), randomTeam);
                player.sendMessage(ChatColor.YELLOW + "You've been assigned to team " + randomTeam + "!");
            }
        }

        // Start countdown
        startCountdown();
        Bukkit.broadcastMessage(ChatColor.GOLD + "Oxygen Heist starting in 10 seconds!");
    }

    private void startCountdown() {
        new BukkitRunnable() {
            int countdown = 10;

            @Override
            public void run() {
                if (countdown > 0) {
                    // Show countdown title
                    for (Player player : Bukkit.getOnlinePlayers()) {
                        player.sendTitle(
                                ChatColor.GREEN.toString() + countdown,
                                ChatColor.GRAY + "Prepare for the heist!",
                                0, 20, 0
                        );
                    }

                    // Update proxy countdown
                    if (proxyAvailable && countdown <= 5) {
                        sendProxyCountdown(countdown, "Oxygen Heist starting!");
                    }

                    countdown--;
                } else {
                    // Start game
                    for (Player player : Bukkit.getOnlinePlayers()) {
                        player.sendTitle(
                                ChatColor.GOLD + "Heist Begins!",
                                ChatColor.YELLOW + "Capture the oxygen point!",
                                10, 40, 10
                        );
                        unfreezePlayer(player);
                    }

                    // Notify proxy game is active
                    if (proxyAvailable) {
                        notifyProxyProgress("Game active - capture the point!");
                    }

                    startGameLoop();
                    cancel();
                }
            }
        }.runTaskTimer(this, 0, 20);
    }

    private void startGameLoop() {
        gameState = GameState.ACTIVE;
        if (bossBar != null) {
            bossBar.setVisible(true);
        }
        gameTime = 0;

        gameTaskId = new BukkitRunnable() {
            @Override
            public void run() {
                if (gameState != GameState.ACTIVE) {
                    cancel();
                    return;
                }

                gameTime++;

                // Check for weapon scatter
                if (gameTime == weaponScatterTime) {
                    scatterWeapons();
                }

                // Check for border shrink start
                if (gameTime == borderShrinkStart) {
                    startBorderShrink();
                }

                // Check for game end
                if (gameTime >= totalGameTime) {
                    if (captureProgress >= 100) {
                        endGame();
                    } else {
                        startOvertime();
                    }
                }

                // Update capture point
                updateCapturePoint();

                // Update BossBar
                updateBossBar();

                // Handle oxygen mechanics
                handleOxygenMechanics();

                // Update proxy with game progress every minute
                if (proxyAvailable && gameTime % 60 == 0) {
                    notifyProxyProgress(String.format("Time: %d/%d, Control: %s, Progress: %d%%",
                            gameTime, totalGameTime,
                            controllingTeam != null ? controllingTeam : "None",
                            captureProgress));
                }
            }
        }.runTaskTimer(this, 0, 20).getTaskId();
    }

    private void updateCapturePoint() {
        if (capturePoint == null) return;

        Set<String> teamsOnPoint = getTeamsOnCapturePoint();

        if (teamsOnPoint.isEmpty()) {
            // No teams on point - progress pauses if not contested
            isContested = false;
            contestingTeams.clear();
        } else if (teamsOnPoint.size() == 1) {
            // Only one team on point
            String teamOnPoint = teamsOnPoint.iterator().next();
            isContested = false;
            contestingTeams.clear();

            if (controllingTeam == null || controllingTeam.equals(teamOnPoint)) {
                // Capturing or maintaining control
                controllingTeam = teamOnPoint;
                if (captureProgress < 100) {
                    captureProgress++;
                    if (captureProgress >= 100) {
                        // Team has fully captured!
                        ChatColor color = teamColors.get(teamOnPoint);
                        broadcastMessage(color + teamOnPoint + ChatColor.GREEN + " has captured the oxygen point!");

                        // Award points for capture via proxy
                        if (proxyAvailable) {
                            for (UUID member : getTeamMembers(teamOnPoint)) {
                                Player player = Bukkit.getPlayer(member);
                                if (player != null) {
                                    awardProxyPoints(player, 25, "Team captured oxygen point");
                                }
                            }
                        }
                    }
                }
            } else {
                // Point is being recaptured
                if (captureProgress > 0) {
                    captureProgress--;
                    if (captureProgress <= 0) {
                        // Point has been recaptured by new team
                        ChatColor color = teamColors.get(teamOnPoint);
                        broadcastMessage(color + teamOnPoint + ChatColor.GREEN + " has taken control of the point!");
                        controllingTeam = teamOnPoint;
                    }
                }
            }
        } else {
            // Multiple teams on point - contested
            isContested = true;
            contestingTeams = teamsOnPoint;
            // Progress pauses during contest
        }
    }

    private Set<String> getTeamsOnCapturePoint() {
        Set<String> teamsOnPoint = ConcurrentHashMap.newKeySet();
        if (capturePoint == null) return teamsOnPoint;

        for (Player player : Bukkit.getOnlinePlayers()) {
            if (spectators.contains(player.getUniqueId())) continue;

            if (player.getLocation().distance(capturePoint) <= captureRadius) {
                String team = getPlayerTeam(player);
                if (team != null) {
                    teamsOnPoint.add(team);
                }
            }
        }
        return teamsOnPoint;
    }

    private void updateBossBar() {
        if (gameState == GameState.ACTIVE && bossBar != null) {
            String title;
            BarColor color;

            if (isContested) {
                title = ChatColor.RED + "CONTESTED! ";
                color = BarColor.RED;

                // Show contesting teams in BossBar text
                if (!contestingTeams.isEmpty()) {
                    StringBuilder contestingText = new StringBuilder();
                    for (String team : contestingTeams) {
                        ChatColor teamColor = teamColors.get(team);
                        contestingText.append(teamColor).append(team).append(" ");
                    }
                    title += contestingText.toString().trim();
                }
            } else {
                title = "";
                color = controllingTeam != null ? getBarColorFromTeam(controllingTeam) : BarColor.WHITE;
            }

            if (controllingTeam != null) {
                ChatColor teamColor = teamColors.get(controllingTeam);
                title += teamColor + controllingTeam + ChatColor.WHITE + " - " + captureProgress + "%";
            } else {
                title += "Neutral - " + captureProgress + "%";
            }

            // Add timer
            int timeLeft = totalGameTime - gameTime;
            if (timeLeft < 0) {
                title += ChatColor.GOLD + " - OVERTIME";
                // Overtime animation
                overtimeAnimation = (overtimeAnimation + 1) % 12;
                if (overtimeAnimation < 3) color = BarColor.YELLOW;
                else if (overtimeAnimation < 6) color = BarColor.YELLOW;
                else if (overtimeAnimation < 9) color = BarColor.RED;
                else color = BarColor.YELLOW;
            } else {
                title += ChatColor.GRAY + " - " + formatTime(timeLeft);
            }

            bossBar.setTitle(title);
            bossBar.setColor(color);
            bossBar.setProgress(captureProgress / 100.0);
        }
    }

    private void handleOxygenMechanics() {
        for (Player player : Bukkit.getOnlinePlayers()) {
            if (spectators.contains(player.getUniqueId())) continue;

            if (capturePoint == null) continue;

            boolean isInCapturePoint = player.getLocation().distance(capturePoint) <= captureRadius;

            if (isInCapturePoint) {
                // Restore oxygen (simulated)
                player.setRemainingAir(player.getMaximumAir());
            } else {
                // Lose oxygen every 10 seconds
                if (gameTime % 10 == 0) {
                    int newAir = player.getRemainingAir() - (player.getMaximumAir() / 10);
                    if (newAir <= 0) {
                        // Apply drowning damage
                        player.damage(2);
                        player.setRemainingAir(0);
                    } else {
                        player.setRemainingAir(newAir);
                    }
                }
            }
        }
    }

    private void scatterWeapons() {
        broadcastMessage(ChatColor.GOLD + "WEAPONS SCATTER!");

        if (gameWorld == null) return;

        // Simple weapon scatter implementation
        for (int i = 0; i < 10; i++) {
            Location dropLocation = getRandomDropLocation();
            if (dropLocation != null) {
                // Spawn chest
                dropLocation.getBlock().setType(Material.CHEST);
            }
        }
    }

    private void startBorderShrink() {
        if (gameWorld == null) return;

        WorldBorder border = gameWorld.getWorldBorder();
        border.setSize(50, 600); // Shrink to 50 over 10 minutes

        borderTaskId = new BukkitRunnable() {
            @Override
            public void run() {
                // Border shrinking logic
                if (border.getSize() <= 50) {
                    cancel();
                }
            }
        }.runTaskTimer(this, 0, 20).getTaskId();
    }

    private void startOvertime() {
        broadcastMessage(ChatColor.GOLD + "OVERTIME! Capture the point to win!");
        // Overtime continues until someone captures the point
    }

    private void endGame() {
        gameState = GameState.ENDED;

        // Determine winners
        String winner = controllingTeam;

        // Show victory titles
        if (winner != null) {
            ChatColor color = teamColors.get(winner);
            for (Player player : Bukkit.getOnlinePlayers()) {
                player.sendTitle(
                        color + winner + " Wins!",
                        ChatColor.YELLOW + "Oxygen supply secured!",
                        10, 60, 20
                );
            }

            // Notify proxy about game completion with winner
            if (proxyAvailable) {
                notifyProxyGameEnded(winner);

                // Award points to winning team members
                for (UUID memberId : getTeamMembers(winner)) {
                    Player member = Bukkit.getPlayer(memberId);
                    if (member != null) {
                        int kills = playerKills.getOrDefault(memberId, 0);
                        awardProxyPoints(member, 100 + kills * 10, "Winning team + kills");
                    }
                }
            }
        } else {
            // No winner - draw game
            if (proxyAvailable) {
                notifyProxyGameEnded("DRAW");
            }
        }

        // Reset after delay
        Bukkit.getScheduler().runTaskLater(this, this::resetGame, 100);
    }

    public void stopGame() {
        if (gameState == GameState.WAITING) return;

        gameState = GameState.ENDED;

        // Cancel tasks
        if (gameTaskId != -1) {
            Bukkit.getScheduler().cancelTask(gameTaskId);
            gameTaskId = -1;
        }
        if (borderTaskId != -1) {
            Bukkit.getScheduler().cancelTask(borderTaskId);
            borderTaskId = -1;
        }

        // Notify proxy about game stop
        if (proxyAvailable) {
            String winner = controllingTeam != null ? controllingTeam : "NONE";
            notifyProxyGameEnded(winner);
        }

        // Display results
        displayResults();
        displayKillLeaderboard();

        // Reset after delay
        Bukkit.getScheduler().runTaskLater(this, this::resetGame, 100);
    }

    private void displayKillLeaderboard() {
        Bukkit.broadcastMessage(ChatColor.GOLD + "=== KILL LEADERBOARD ===");

        playerKills.entrySet().stream()
                .sorted(Map.Entry.<UUID, Integer>comparingByValue().reversed())
                .limit(5)
                .forEachOrdered(entry -> {
                    Player player = Bukkit.getPlayer(entry.getKey());
                    if (player != null) {
                        String teamName = getPlayerTeam(player);
                        ChatColor teamColor = teamName != null ? teamColors.get(teamName) : ChatColor.WHITE;
                        Bukkit.broadcastMessage(teamColor + player.getName() +
                                ChatColor.WHITE + " - " +
                                ChatColor.RED + entry.getValue() + " kills");

                        // Award points via proxy for kills
                        if (proxyAvailable) {
                            awardProxyPoints(player, entry.getValue() * 5, "Kill points");
                        }
                    }
                });
    }

    private void displayResults() {
        // Display final results and rankings
        if (controllingTeam != null) {
            ChatColor color = teamColors.get(controllingTeam);
            Bukkit.broadcastMessage(ChatColor.GOLD + "=== FINAL RESULTS ===");
            Bukkit.broadcastMessage(ChatColor.YELLOW + "1st: " + color + controllingTeam);
            Bukkit.broadcastMessage(ChatColor.GREEN + "Capture Progress: " + captureProgress + "%");
        }
    }

    private void resetGame() {
        gameState = GameState.WAITING;
        controllingTeam = null;
        captureProgress = 0;
        isContested = false;
        contestingTeams.clear();
        playerKills.clear();
        spectators.clear();
        gameTime = 0;
        overtimeAnimation = 0;

        if (bossBar != null) {
            bossBar.setVisible(false);
        }

        // Reset world border
        initializeWorldBorder();

        // Reset player displays and inventory
        for (Player player : Bukkit.getOnlinePlayers()) {
            player.setGameMode(GameMode.ADVENTURE);
            player.getInventory().clear();
            player.setHealth(20);
            player.setFoodLevel(20);
            player.setRemainingAir(player.getMaximumAir());
            player.setDisplayName(player.getName());
            player.setPlayerListName(player.getName());
        }
    }

    private Location getRandomDropLocation() {
        if (gameWorld == null) return null;

        Random random = new Random();

        int x = random.nextInt(200) - 100;
        int z = random.nextInt(200) - 100;
        int y = gameWorld.getHighestBlockYAt(x, z) + 10;

        return new Location(gameWorld, x, y, z);
    }

    // Team management methods
    public String getPlayerTeam(Player player) {
        return playerTeams.get(player.getUniqueId());
    }

    public boolean areTeammates(Player player1, Player player2) {
        String team1 = getPlayerTeam(player1);
        String team2 = getPlayerTeam(player2);
        return team1 != null && team1.equals(team2);
    }

    public List<UUID> getTeamMembers(String teamName) {
        TeamData team = teams.get(teamName);
        return team != null ? new ArrayList<>(team.members) : new ArrayList<>();
    }

    public ChatColor getTeamColor(String teamName) {
        return teamColors.get(teamName);
    }

    public Set<String> getAllTeams() {
        return teams.keySet();
    }

    public Location getTeamSpawn(String teamName) {
        return teamSpawns.get(teamName);
    }

    public boolean hasTeamData() {
        return !teams.isEmpty();
    }

    public boolean isWorldInitialized() {
        return worldInitialized;
    }

    public boolean isProxyAvailable() {
        return proxyAvailable;
    }

    public Object getProxyConnector() {
        return proxyConnector;
    }

    // Utility methods
    private BarColor getBarColorFromTeam(String teamName) {
        ChatColor color = teamColors.get(teamName);

        switch (color) {
            case RED: return BarColor.RED;
            case YELLOW: return BarColor.YELLOW;
            case GREEN: return BarColor.GREEN;
            case BLUE: return BarColor.BLUE;
            case AQUA: return BarColor.BLUE;
            case DARK_PURPLE: return BarColor.PURPLE;
            case LIGHT_PURPLE: return BarColor.PINK;
            case GOLD: return BarColor.YELLOW;
            default: return BarColor.WHITE;
        }
    }

    private void freezePlayer(Player player) {
        player.setWalkSpeed(0);
        player.setFlySpeed(0);
        player.setInvulnerable(true);
    }

    private void unfreezePlayer(Player player) {
        player.setWalkSpeed(0.2f);
        player.setFlySpeed(0.1f);
        player.setInvulnerable(false);
    }

    private String formatTime(int seconds) {
        int minutes = seconds / 60;
        int secs = seconds % 60;
        return String.format("%d:%02d", minutes, secs);
    }

    private void broadcastMessage(String message) {
        Bukkit.broadcastMessage(ChatColor.translateAlternateColorCodes('&', message));
    }

