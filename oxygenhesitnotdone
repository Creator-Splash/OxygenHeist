    public GameState getGameState() { return gameState; }
    public int getGameTime() { return gameTime; }
    public Map<UUID, Integer> getPlayerKills() { return playerKills; }
    public Set<UUID> getSpectators() { return spectators; }
    public BossBar getBossBar() { return bossBar; }
    public int getBorderShrinkStart() { return borderShrinkStart; }
    public World getGameWorld() { return gameWorld; }

    // Team data class
    private static class TeamData {
        public final String name;
        public final ChatColor color;
        public final Set<UUID> members;

        public TeamData(String name, ChatColor color) {
            this.name = name;
            this.color = color;
            this.members = ConcurrentHashMap.newKeySet();
        }
    }
