            // Fallback to simpler method
            try {
                JavaVFrame proxyConnectorClass;
                java.lang.reflect.Method method = proxyConnectorClass.getMethod("notifyGameEnded", String.class, String.class);
                method.invoke(proxyConnector, "OxygenHeist", winner);
            } catch (Exception e2) {
