    private boolean initializeTeams() {
        try {
            // Get all online players
            List<Player> onlinePlayers = new ArrayList<>(Bukkit.getOnlinePlayers());
            if (onlinePlayers.isEmpty()) {
                getLogger().warning("No players online to assign to teams");
                return true; // This is not a critical error
            }

            Collections.shuffle(onlinePlayers); // Randomize for fairness

            String[] teamNames = {"Orca", "Seahorse", "Turtle", "Dolphin", "Swordfish", "Stingray", "Jellyfish", "Octopus"};

            // Distribute players evenly across teams
            for (int i = 0; i < onlinePlayers.size(); i++) {
                Player player = onlinePlayers.get(i);
                String teamName = teamNames[i % teamNames.length];

                // Add player to team
                teams.computeIfAbsent(teamName, name -> new TeamData(name, teamColors.get(name)))
                        .members.add(player.getUniqueId());
                playerTeams.put(player.getUniqueId(), teamName);
            }

            // Setup Minecraft scoreboard teams
            setupMinecraftTeams();

            getLogger().info("Initialized " + teams.size() + " teams with " + onlinePlayers.size() + " players");
            return true;
        } catch (Exception e) {
            getLogger().warning("Failed to initialize teams: " + e.getMessage());
            return false;
        }
    }

    private boolean initializeWorldBorder() {
        if (gameWorld == null) {
            getLogger().warning("Cannot initialize world border: world is null");
            return false;
        }

        try {
            WorldBorder border = gameWorld.getWorldBorder();
            border.setCenter(0, 0);
            border.setSize(298);
            border.setDamageAmount(2.0);
            border.setDamageBuffer(5.0);
            border.setWarningDistance(10);
            getLogger().info("World border initialized");
            return true;
        } catch (Exception e) {
            getLogger().warning("Failed to initialize world border: " + e.getMessage());
            return false;
        }
    }

    private void setupMinecraftTeams() {
        try {
            org.bukkit.scoreboard.Scoreboard scoreboard = Bukkit.getScoreboardManager().getMainScoreboard();
            if (scoreboard == null) {
                getLogger().warning("Cannot setup Minecraft teams: scoreboard is null");
                return;
            }

            // Clear existing teams to avoid conflicts
            for (Team team : scoreboard.getTeams()) {
                try {
                    team.unregister();
                } catch (Exception e) {
                    // Ignore errors when unregistering teams
                }
            }

            // Register Minecraft teams
            for (String teamName : teams.keySet()) {
                try {
                    Team mcTeam = scoreboard.registerNewTeam(teamName);
                    mcTeam.setAllowFriendlyFire(false);

                    // Set team color
                    ChatColor color = teamColors.get(teamName);
                    if (color != null) {
                        mcTeam.setColor(color);
                    }

                    // Add team members
                    TeamData teamData = teams.get(teamName);
                    for (UUID member : teamData.members) {
                        Player player = Bukkit.getPlayer(member);
                        if (player != null) {
                            mcTeam.addEntry(player.getName());
                            // Set player display name with team color
                            player.setDisplayName(color + player.getName() + ChatColor.RESET);
                            player.setPlayerListName(color + player.getName());
                        }
                    }

                    getLogger().info("Registered team: " + teamName + " with " + mcTeam.getEntries().size() + " members");
                } catch (Exception e) {
                    getLogger().warning("Failed to register team " + teamName + ": " + e.getMessage());
                }
            }
        } catch (Exception e) {
            getLogger().warning("Failed to setup Minecraft teams: " + e.getMessage());
        }
    }

