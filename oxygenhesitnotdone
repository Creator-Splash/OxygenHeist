    @Override
    public boolean onCommand(CommandSender sender, Command command, String label, String[] args) {
        // Allow console and OPs only for now
        if (!(sender instanceof org.bukkit.command.ConsoleCommandSender) && !sender.isOp()) {
            sender.sendMessage(ChatColor.RED + "You need to be OP to use this command!");
            return true;
        }

        if (!worldInitialized && !command.getName().equalsIgnoreCase("status") &&
                !command.getName().equalsIgnoreCase("proxystatus")) {
            sender.sendMessage(ChatColor.RED + "Plugin not fully initialized yet. Please wait or use /status to check.");
            return true;
        }

        switch (command.getName().toLowerCase()) {
            case "start":
                startGame();
                sender.sendMessage(ChatColor.GREEN + "Starting Oxygen Heist game...");
                break;
            case "stop":
                stopGame();
                sender.sendMessage(ChatColor.RED + "Stopping Oxygen Heist game...");
                break;
            case "debugteams":
                sender.sendMessage(ChatColor.YELLOW + "=== Team Data Debug ===");
                for (String team : teams.keySet()) {
                    int memberCount = teams.get(team).members.size();
                    sender.sendMessage(ChatColor.WHITE + "- " + team + ": " + memberCount + " members");
                }
                if (teams.isEmpty()) {
                    sender.sendMessage(ChatColor.RED + "No teams available!");
                }
                break;
            case "setupteams":
                setupMinecraftTeams();
                sender.sendMessage(ChatColor.GREEN + "Minecraft teams setup completed");
                break;
            case "resetteams":
                teams.clear();
                playerTeams.clear();
                initializeTeams();
                sender.sendMessage(ChatColor.GREEN + "Teams reset and reassigned");
                break;
            case "status":
                sender.sendMessage(ChatColor.YELLOW + "=== OxygenHeist Status ===");
                sender.sendMessage(ChatColor.WHITE + "World: " + (gameWorld != null ? gameWorld.getName() : "null"));
                sender.sendMessage(ChatColor.WHITE + "Teams: " + teams.size());
                sender.sendMessage(ChatColor.WHITE + "Players: " + playerTeams.size());
                sender.sendMessage(ChatColor.WHITE + "Game State: " + gameState);
                sender.sendMessage(ChatColor.WHITE + "Initialized: " + worldInitialized);
                sender.sendMessage(ChatColor.WHITE + "Capture Progress: " + captureProgress + "%");
                sender.sendMessage(ChatColor.WHITE + "Proxy Available: " + proxyAvailable);
                break;
            case "debug":
                if (sender instanceof Player) {
                    debugPlayer((Player) sender);
                } else {
                    sender.sendMessage(ChatColor.YELLOW + "Debug info - World: " + gameWorld + ", State: " + gameState + ", Proxy: " + proxyAvailable);
                }
                break;
            case "forceinit":
                initializePlugin();
                sender.sendMessage(ChatColor.GREEN + "Forced plugin re-initialization");
                break;
            case "proxystatus":
                sender.sendMessage(ChatColor.YELLOW + "=== ProxyConnector Status ===");
                sender.sendMessage(ChatColor.WHITE + "Available: " + proxyAvailable);
                if (proxyAvailable) {
                    try {
                        Class<?> proxyConnectorClass = Class.forName("creatorsplash.creatorsplashcore.api.ProxyConnector");
                        java.lang.reflect.Method getEventIdMethod = proxyConnectorClass.getMethod("getCurrentEventId");
                        java.lang.reflect.Method getServerNameMethod = proxyConnectorClass.getMethod("getServerName");
                        java.lang.reflect.Method isConnectedMethod = proxyConnectorClass.getMethod("isConnected");

                        String eventId = (String) getEventIdMethod.invoke(proxyConnector);
                        String serverName = (String) getServerNameMethod.invoke(proxyConnector);
                        boolean connected = (Boolean) isConnectedMethod.invoke(proxyConnector);

                        sender.sendMessage(ChatColor.WHITE + "Connected: " + connected);
                        sender.sendMessage(ChatColor.WHITE + "Event ID: " + eventId);
                        sender.sendMessage(ChatColor.WHITE + "Server: " + serverName);
                    } catch (Exception e) {
                        sender.sendMessage(ChatColor.RED + "Error getting proxy details: " + e.getMessage());
                    }
                }
                break;
            default:
                sender.sendMessage(ChatColor.RED + "Unknown command. Available: start, stop, status, debugteams, setupteams, resetteams, debug, forceinit, proxystatus");
                break;
        }
        return true;
    }

