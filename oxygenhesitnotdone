    @Override
    public void onEnable() {
        getLogger().info("OxygenHeist plugin starting...");

        // Initialize ProxyConnector safely
        initializeProxyConnector();

        // Initialize BossBar first (safe)
        try {
            bossBar = Bukkit.createBossBar("Oxygen Heist", BarColor.WHITE, BarStyle.SOLID);
            bossBar.setVisible(false);
            getLogger().info("BossBar initialized");
        } catch (Exception e) {
            getLogger().warning("Failed to initialize BossBar: " + e.getMessage());
        }

        // Register events (safe)
        try {
            getServer().getPluginManager().registerEvents(new GameEvents(this), this);
            getLogger().info("Events registered");
        } catch (Exception e) {
            getLogger().warning("Failed to register events: " + e.getMessage());
        }

        // Wait for server to fully start before initializing world-dependent components
        Bukkit.getScheduler().runTaskLater(this, () -> {
            initializePlugin();
        }, 40L); // Wait 2 seconds for server to fully start
    }

    private void initializeProxyConnector() {
        try {
            // Use reflection to safely check if ProxyConnector is available
            Class<?> proxyConnectorClass = Class.forName("creatorsplash.creatorsplashcore.api.ProxyConnector");
            java.lang.reflect.Method getInstanceMethod = proxyConnectorClass.getMethod("getInstance");
            proxyConnector = getInstanceMethod.invoke(null);

            // Check if connected
            java.lang.reflect.Method isConnectedMethod = proxyConnectorClass.getMethod("isConnected");
            proxyAvailable = (Boolean) isConnectedMethod.invoke(proxyConnector);

            if (proxyAvailable) {
                getLogger().info("ProxyConnector initialized successfully");

                // Notify proxy that game is preparing
                java.lang.reflect.Method notifyGamePreparingMethod = proxyConnectorClass.getMethod("notifyGamePreparing", String.class, String.class);
                notifyGamePreparingMethod.invoke(proxyConnector, "OxygenHeist", "Loading world and initializing teams...");
            } else {
                getLogger().warning("ProxyConnector is not connected - running in standalone mode");
            }
        } catch (Exception e) {
            getLogger().info("ProxyConnector not available - running in standalone mode: " + e.getMessage());
            proxyAvailable = false;
            proxyConnector = null;
        }
    }

    private void initializePlugin() {
        getLogger().info("Starting plugin initialization...");

        // Notify proxy about initialization progress
        if (proxyAvailable) {
            notifyProxyProgress("Initializing world...");
        }

        // Step 1: Initialize world
        if (!initializeWorld()) {
            getLogger().severe("CRITICAL: Failed to initialize world! Plugin cannot function.");
            getLogger().severe("Please restart the server or ensure a world is loaded.");
            return;
        }

        if (proxyAvailable) {
            notifyProxyProgress("Setting up team spawns...");
        }

        // Step 2: Initialize team spawns
        if (!initializeTeamSpawns()) {
            getLogger().severe("CRITICAL: Failed to initialize team spawns!");
            return;
        }

        if (proxyAvailable) {
            notifyProxyProgress("Setting up capture point...");
        }

        // Step 3: Initialize capture point
        if (!initializeCapturePoint()) {
            getLogger().severe("CRITICAL: Failed to initialize capture point!");
            return;
        }

        if (proxyAvailable) {
            notifyProxyProgress("Initializing teams...");
        }

        // Step 4: Initialize teams
        if (!initializeTeams()) {
            getLogger().warning("No teams initialized - no players online?");
        }

        if (proxyAvailable) {
            notifyProxyProgress("Setting up world border...");
        }

        // Step 5: Initialize world border
        if (!initializeWorldBorder()) {
            getLogger().warning("Failed to initialize world border");
        }

        worldInitialized = true;

        // Notify proxy that server is ready
        if (proxyAvailable) {
            notifyProxyServerReady();
            notifyProxyProgress("Ready for game start");
        }

        getLogger().info("OxygenHeist plugin enabled successfully!");
        getLogger().info("World: " + (gameWorld != null ? gameWorld.getName() : "null"));
        getLogger().info("Teams: " + teams.size() + ", Players: " + playerTeams.size());
        getLogger().info("Proxy connector: " + (proxyAvailable ? "Available" : "Not available"));
    }

    // Proxy helper methods using reflection
    private void notifyProxyProgress(String message) {
        if (!proxyAvailable || proxyConnector == null) return;

        try {
            Class<?> proxyConnectorClass = Class.forName("creatorsplash.creatorsplashcore.api.ProxyConnector");
            java.lang.reflect.Method method = proxyConnectorClass.getMethod("notifyGameProgress", String.class, String.class);
            method.invoke(proxyConnector, "OxygenHeist", message);
        } catch (Exception e) {
            // Silently fail - proxy might have disconnected
        }
    }

