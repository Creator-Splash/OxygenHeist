    // Rest of your existing methods remain the same until we get to the game logic
    private boolean initializeWorld() {
        try {
            // Method 1: Try to get default world
            if (!Bukkit.getWorlds().isEmpty()) {
                gameWorld = Bukkit.getWorlds().get(0);
                getLogger().info("World found via getWorlds(): " + gameWorld.getName());
                return true;
            }

            // Method 2: Try common world names
            String[] worldNames = {"world", "world_nether", "world_the_end", "overworld"};
            for (String worldName : worldNames) {
                gameWorld = Bukkit.getWorld(worldName);
                if (gameWorld != null) {
                    getLogger().info("World found by name: " + worldName);
                    return true;
                }
            }

            // Method 3: Try to get any world
            for (World world : Bukkit.getWorlds()) {
                gameWorld = world;
                getLogger().info("World found in worlds list: " + world.getName());
                return true;
            }

            // Method 4: Last resort - try to create a world reference
            try {
                gameWorld = Bukkit.getWorlds().get(0);
            } catch (Exception e) {
                getLogger().severe("All world initialization methods failed!");
                return false;
            }

        } catch (Exception e) {
            getLogger().severe("Exception during world initialization: " + e.getMessage());
            return false;
        }

        return gameWorld != null;
    }

